# Auth0 Configuration
# Get these from your Auth0 application settings
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your_client_id

# Anthropic API
# Used for Review Ready document generation
VITE_ANTHROPIC_API_KEY=your_api_key

# API Mode
# fakestore = uses FakeStoreAPI (assignment submission mode)
# visible   = uses real Visible backend / localStorage
VITE_API_MODE=fakestore
